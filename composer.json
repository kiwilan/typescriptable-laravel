{
  "name": "kiwilan/typescriptable-laravel",
  "description": "PHP package for Laravel to type Eloquent models, routes, Spatie Settings with autogenerated TypeScript. If you want to use some helpers with Inertia, you can install associated NPM package.",
  "version": "3.1.06",
  "keywords": [
    "kiwilan",
    "laravel",
    "typescriptable-laravel",
    "php",
    "typescript",
    "ts",
    "inertia",
    "eloquent",
    "model",
    "routes",
    "vue"
  ],
  "homepage": "https://github.com/kiwilan/typescriptable-laravel",
  "license": "MIT",
  "authors": [
    {
      "name": "Kiwilan",
      "email": "ewilan.riviere@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2 || ^8.4",
    "illuminate/console": "^11.0 || ^12.0 || ^13.0",
    "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
    "illuminate/database": "^11.0 || ^12.0 || ^13.0",
    "illuminate/filesystem": "^11.0 || ^12.0 || ^13.0",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "phpdocumentor/type-resolver": "^1.8",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "laravel/pint": "^1.15",
    "orchestra/testbench": "^9.0 || ^10.0",
    "pestphp/pest": "^2.34",
    "pestphp/pest-plugin-laravel": "^2.4",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^1.11",
    "phpstan/phpstan-deprecation-rules": "^1.2",
    "phpstan/phpstan-phpunit": "^1.4",
    "spatie/laravel-ray": "^1.36"
  },
  "autoload": {
    "psr-4": {
      "Kiwilan\\Typescriptable\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kiwilan\\Typescriptable\\Tests\\": "tests"
    }
  },
  "scripts": {
    "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
    "test": "vendor/bin/pest",
    "test-filter": "vendor/bin/pest --filter",
    "test-parallel": "vendor/bin/pest --parallel",
    "test-coverage": "vendor/bin/pest --coverage",
    "test-coverage-parallel": "vendor/bin/pest --parallel --coverage",
    "analyse": "vendor/bin/phpstan analyse",
    "format": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Kiwilan\\Typescriptable\\TypescriptableServiceProvider"
      ],
      "aliases": {
        "Typescriptable": "Kiwilan\\Typescriptable\\Facades\\Typescriptable"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
